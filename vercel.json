{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/index", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/sluzby.html", "destination": "/sluzby", "permanent": true },
    { "source": "/cenik.html", "destination": "/cenik", "permanent": true },
    { "source": "/o-nas.html", "destination": "/o-nas", "permanent": true },
    { "source": "/kontakt.html", "destination": "/kontakt", "permanent": true },
    { "source": "/zamecnik-praha-1.html", "destination": "/zamecnik-praha-1", "permanent": true },
    { "source": "/zamecnik-praha-2.html", "destination": "/zamecnik-praha-2", "permanent": true },
    { "source": "/zamecnik-praha-3.html", "destination": "/zamecnik-praha-3", "permanent": true },
    { "source": "/zamecnik-praha-4.html", "destination": "/zamecnik-praha-4", "permanent": true },
    { "source": "/zamecnik-praha-5.html", "destination": "/zamecnik-praha-5", "permanent": true },
    { "source": "/zamecnik-praha-6.html", "destination": "/zamecnik-praha-6", "permanent": true },
    { "source": "/zamecnik-praha-7.html", "destination": "/zamecnik-praha-7", "permanent": true },
    { "source": "/zamecnik-praha-8.html", "destination": "/zamecnik-praha-8", "permanent": true },
    { "source": "/zamecnik-praha-9.html", "destination": "/zamecnik-praha-9", "permanent": true },
    { "source": "/zamecnik-praha-10.html", "destination": "/zamecnik-praha-10", "permanent": true }
  ]
}
